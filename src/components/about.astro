---
import { Icon } from 'astro-icon/components';
import esAboutData from '../data/about.json';
import enAboutData from '../data/en/about.json';
import { t, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const aboutData = lang === 'en' ? enAboutData : esAboutData;

const highlights = [
  { icon: 'mdi:account-tie', label: t(lang, 'about.highlight.leadership') },
  { icon: 'mdi:sitemap', label: t(lang, 'about.highlight.architecture') },
  { icon: 'mdi:database-cog', label: t(lang, 'about.highlight.dbOptimization') },
  { icon: 'mdi:robot', label: t(lang, 'about.highlight.aiAutomation') },
];

function highlight(text: string, terms: string[]) {
  let html = text;
  for (const term of terms) {
    html = html.split(term).join(`<span class="text-maintext font-semibold">${term}</span>`);
  }
  return html;
}

const paragraphsHtml = aboutData.paragraphs.map((p) => highlight(p, aboutData.highlightTerms));
---

<section id="about" class="section-container">
  <div class="container mx-auto">
    <div class="about-header mb-12">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-maintext mb-2 flex items-center gap-4">
        <span class="text-accent">/</span> {t(lang, 'about.title')}
      </h2>
      <p class="text-subtext font-body text-sm max-w-md">
        {t(lang, 'about.subtitle')}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
      <div class="about-content lg:col-span-2 bg-accent/5 border border-accent/10 rounded-2xl p-6 md:p-10 backdrop-blur-sm">
        {paragraphsHtml.map((html, i) => (
          <p class={`text-subtext font-body text-base md:text-lg leading-relaxed ${i > 0 ? 'mt-4' : ''}`} set:html={html} />
        ))}
      </div>

      <div class="grid grid-cols-2 gap-4">
        {highlights.map((item) => (
          <div class="about-card bg-accent/5 border border-accent/10 rounded-2xl p-5 flex flex-col items-center text-center gap-3 hover:border-accent/40 hover:bg-accent/10 transition-all duration-300">
            <Icon name={item.icon} class="w-8 h-8 text-accent" />
            <span class="text-maintext font-body text-xs font-medium leading-tight">{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about-header,
  .about-content,
  .about-card {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .about-header.reveal,
  .about-content.reveal,
  .about-card.reveal {
    opacity: 1 !important;
    transform: translateY(0);
  }
</style>

<script>
  function revealAbout() {
    const targets = document.querySelectorAll('.about-header, .about-content, .about-card');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          const index = Array.from(targets).indexOf(entry.target);
          setTimeout(() => {
            entry.target.classList.add('reveal');
          }, (index % 4) * 120);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -10px 0px' });

    targets.forEach((el) => observer.observe(el));
  }

  revealAbout();
  document.addEventListener('astro:after-swap', revealAbout);
</script>
