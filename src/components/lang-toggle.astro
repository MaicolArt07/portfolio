---
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const otherLang: Lang = lang === 'es' ? 'en' : 'es';
const otherUrl = getRelativeLocaleUrl(otherLang);
const label = otherLang === 'en' ? 'EN' : 'ES';
const ariaLabel = otherLang === 'en' ? 'Switch to English' : 'Cambiar a español';
---

<a id="lang-toggle" href={otherUrl} aria-label={ariaLabel} title={ariaLabel}>
  {label}
</a>

<style>
  #lang-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 9999px;
    background: transparent;
    border: 1px solid color-mix(in srgb, var(--color-maintext), transparent 80%);
    color: var(--color-maintext);
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  #lang-toggle:hover {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-background);
  }
</style>
