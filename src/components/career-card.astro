---
import { Icon } from 'astro-icon/components';
import techData from '../data/tech.json';

interface Props {
  item: {
    period: string;
    role: string;
    company: string;
    type?: string;
    achievements: string[];
    tech: string[];
  };
  variant: 'mobile' | 'desktop-left' | 'desktop-right';
}

const { item, variant } = Astro.props;

const isLeft = variant === 'desktop-left';

const alignmentClass = isLeft ? "text-right" : "";
const listAlignmentClass = isLeft ? "items-end text-right" : "items-start";
const techContainerClasses = `flex flex-wrap gap-2 ${isLeft ? 'justify-end' : ''}`;

const iconMap: Record<string, string> = Object.fromEntries(
  techData.categories.flatMap((category) =>
    category.skills.map((skill) => [skill.name, skill.icon])
  )
);
---

<div class={`bg-accent/5 border border-accent/10 p-4 md:p-6 rounded-2xl hover:border-accent/40 transition-all group ${alignmentClass}`}>
  <span class={`font-mono text-xs tracking-widest uppercase text-accent/75`}>{item.period}</span>
  <h3 class="text-xl font-heading font-bold text-maintext mt-1">{item.role}</h3>
  <p class="text-accent text-sm">{item.company}</p>
  {item.type && <p class="text-subtext/70 text-xs mb-4">{item.type}</p>}

  <ul class={`flex flex-col gap-1.5 mb-4 ${listAlignmentClass}`}>
    {item.achievements.map((achievement: string) => (
      <li class="text-subtext font-body text-sm leading-relaxed">
        {achievement}
      </li>
    ))}
  </ul>

  <div class={techContainerClasses}>
    {item.tech.map((techName: string) => (
      <span class="flex items-center gap-1.5 rounded-md text-[10px] px-2 md:px-3 py-1 bg-accent/5 border border-accent/10 text-accent/80 group-hover:border-accent/40 group-hover:text-accent">
        {iconMap[techName] && <Icon name={iconMap[techName]} class="w-3 h-3" />}
        {techName}
      </span>
    ))}
  </div>
</div>
