---
import { Icon } from 'astro-icon/components';
import esData from '../data/home.json';
import enData from '../data/en/home.json';
import { resolveAssetImage } from '../utils/images';
import { Image } from 'astro:assets';
import { t, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

//Data Definitions
interface Social {
  name: string;
  url: string;
  icon: string;
}

interface ProfileData {
  name: string;
  photoUrl: string;
  role: string;
  specialties: string[];
  intro: string;
  introHtml: string;
  resumeUrl: string;
  socials: Social[];
}

const { lang = 'es' } = Astro.props;
const isApiLive = import.meta.env.PROD; // Auto true in production
const BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;

let data: ProfileData; // data as ProfileData

if (isApiLive && BASE_URL) {
  try {
    const response = await fetch(`${BASE_URL}/home`);
    if (!response.ok) throw new Error('Network response was not ok');
    data = await response.json();
  } catch (error) {
    console.error("API Fetch failed, falling back to mock data", error);
    data = (lang === 'en' ? enData : esData) as ProfileData;
  }
} else {
  data = (lang === 'en' ? enData : esData) as ProfileData;
}

const { name, photoUrl, role, specialties, intro, introHtml, resumeUrl, socials } = data;
const profileImage = await resolveAssetImage(photoUrl);
const resumeHref = resumeUrl.startsWith('http') ? resumeUrl : `${import.meta.env.BASE_URL}${resumeUrl}`;
---

<section id="home" class="flex flex-col items-center justify-center section-container md:pt-30 gap-1 min-h-[80vh] text-center">
  <div class="relative group mb-2 reveal-content" style="animation-delay: 100ms;">
    <div class="balloon-float w-20 h-20 md:w-24 md:h-24 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)]">
      <!-- Use Astro Image tag for optimization, fallback to a generic avatar icon -->
      {profileImage ? (
        <Image
          src={profileImage}
          alt={name}
          class="w-full h-full object-cover scale-110"
          loading="eager"
        />
      ) : photoUrl ? (
        <img
          src={photoUrl}
          alt={name}
          class="w-full h-full object-cover scale-110"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          loading="eager"
        />
      ) : null}
      <div
        class="w-full h-full items-center justify-center bg-gradient-to-br from-accent/25 to-accent/5"
        style={`display:${profileImage || photoUrl ? 'none' : 'flex'};`}
      >
        <Icon name="mdi:account-circle" class="w-14 h-14 md:w-16 md:h-16 text-accent/80" />
      </div>
    </div>
    <div class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[80px] opacity-20"></div>
  </div>

    <div class="reveal-content" style="animation-delay: 200ms;">
    <p class="font-body font-light text-gray leading-relaxed">
      {t(lang, 'hero.greeting')}
    </p>
  </div>

  <div class="px-6 sm:px-14 md:px-18 lg:px-40 max-w-360 mx-auto relative z-0 reveal-content" style="animation-delay: 300ms;">
    <h1 class="text-5xl md:text-7xl font-heading font-bold text-maintext tracking-tight">
      {name}
    </h1>
    <p class="text-accent font-heading font-semibold text-lg md:text-xl mt-2">
      {role}
    </p>
    <br>
    <p
      class="text-gray font-body text-lg leading-relaxed"
      set:html={intro}
    />
  </div>

  {specialties && specialties.length > 0 && (
    <div class="flex flex-wrap justify-center gap-2 max-w-2xl reveal-content" style="animation-delay: 350ms;">
      {specialties.map((specialty: string) => (
        <span class="rounded-full text-xs px-4 py-1.5 bg-accent/5 border border-accent/20 text-accent/90 font-body">
          {specialty}
        </span>
      ))}
    </div>
  )}

  <div class="flex flex-wrap items-center justify-center gap-4 mt-8 mb-4 reveal-content" style="animation-delay: 400ms;">
    <a
      href={resumeHref}
      target="_blank"
      rel="noopener noreferrer"
      class="group relative inline-flex items-center justify-center px-10 py-2 bg-white/5 border border-white/10 rounded-full text-maintext font-body transition-all duration-300

             <!-- /* Mobile: Always active */ -->
             border-accent/50 bg-accent/10 shadow-[0_0_20px_rgba(var(--accent-rgb),0.3)]

             <!-- /* Desktop: Reset and hover */ -->
             md:border-accent/50 md:bg-accent/10 md:shadow-none md:hover:border-accent/50 md:hover:bg-accent/10 md:hover:shadow-[0_0_20px_rgba(var(--accent-rgb),0.3)]
             hover:scale-105"
    >
      <div class="flex flex-col items-center justify-center text-center">
        <span class="tracking-wide text-sm md:text-base font-medium transition-transform duration-300 md:translate-y-2 md:group-hover:translate-y-0">
          {t(lang, 'hero.downloadCV')}
        </span>

        <span class="text-[10px] text-subtext font-light whitespace-nowrap transition-all duration-300
                     /* Mobile: Always visible */
                     opacity-100 translate-y-0
                     /* Desktop: Hidden until hover */
                     md:opacity-0 md:translate-y-1 md:group-hover:opacity-100 md:group-hover:translate-y-0">
          {t(lang, 'hero.downloadPdf')}
        </span>
      </div>

      <div class="absolute inset-0 rounded-full blur-md bg-accent/20 -z-10 opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-500"></div>
    </a>

    <a
      href="#contact"
      class="inline-flex items-center justify-center px-8 py-3.5 rounded-full border border-maintext/15 text-maintext font-body text-sm md:text-base font-medium transition-all duration-300 hover:border-accent/50 hover:bg-accent/10 hover:scale-105"
    >
      {t(lang, 'hero.contactMe')}
    </a>

    <a
      href="#projects"
      class="inline-flex items-center justify-center px-8 py-3.5 rounded-full border border-maintext/15 text-maintext font-body text-sm md:text-base font-medium transition-all duration-300 hover:border-accent/50 hover:bg-accent/10 hover:scale-105"
    >
      {t(lang, 'hero.viewProjects')}
    </a>
</div>

  <div class="flex gap-6 mt-4 reveal-content" style="animation-delay: 500ms;">
    {socials.filter((social) => social.url && social.url !== "#" && social.url !== "").map((social) => (
      <a 
        href={social.url} 
        target="_blank" 
        class="group relative flex flex-col items-center justify-center transition-all duration-300 hover:scale-110"
      >
        <Icon 
        name={social.icon} 
        class="w-8 h-8 text-maintext group-hover:text-accent transition-colors duration-300" 
      />

      <span class="absolute -bottom-6 scale-0 opacity-0 group-hover:scale-100 group-hover:opacity-100 transition-all duration-300 text-xs text-accent font-body">
        {social.name}
      </span>
      </a>
    ))}
  </div>
</section>


<style is:global>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  /* profile photo floating animation */

  /* When combined, the animation rule automatically merges these transforms */
  .avatar-container {
    animation: float 5s ease-in-out infinite alternate, wobble 7s ease-in-out infinite alternate;
  }

  .balloon-float {
    will-change: transform;
    animation: floating-balloon 8s ease-in-out infinite;
  }

  @keyframes floating-balloon {
    0% {
      transform: translate(0, 0) rotate(0deg);
    }
    33% {
      /* Moves up and slightly right */
      transform: translate(3px, -8px) rotate(1deg);
    }
    66% {
      /* Drifts left and stays elevated */
      transform: translate(-3px, -4px) rotate(-1deg);
    }
    100% {
      /* Returns to start */
      transform: translate(0, 0) rotate(0deg);
    }
  }
</style>
