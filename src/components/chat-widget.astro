---
import { Icon } from 'astro-icon/components';
import { buildKnowledgeBase } from '../utils/chatKnowledge.js';
import { t, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;

// Built once at build time from the same JSON files that power the rest of
// the site (src/data/) — adding a project there makes it searchable here
// automatically. Runs 100% in the visitor's browser afterwards: no backend,
// no API key, no network call. See src/utils/chatRetrieval.js for the
// matching logic.
const knowledgeBase = buildKnowledgeBase(lang);

const replies = {
  whoAreYouReply: t(lang, 'chat.whoAreYouReply'),
  thanksReply: t(lang, 'chat.thanksReply'),
  greetingReply: t(lang, 'chat.greetingReply'),
  noInfoReply: t(lang, 'chat.noInfoReply'),
  processingError: t(lang, 'chat.processingError'),
};

// Escape "<" so a literal "</script>" inside any data string can't break out
// of the embedding tags below.
const knowledgeBaseJson = JSON.stringify(knowledgeBase).replace(/</g, '\\u003c');
const chatConfigJson = JSON.stringify({ lang, replies }).replace(/</g, '\\u003c');

const suggestedQuestions = [
  t(lang, 'chat.suggested1'),
  t(lang, 'chat.suggested2'),
  t(lang, 'chat.suggested3'),
  t(lang, 'chat.suggested4'),
  t(lang, 'chat.suggested5'),
  t(lang, 'chat.suggested6'),
];
---

<div id="chat-widget">
  <script type="application/json" id="chat-knowledge-data" is:inline set:html={knowledgeBaseJson} />
  <script type="application/json" id="chat-config-data" is:inline set:html={chatConfigJson} />
    <button id="chat-toggle" aria-label={t(lang, 'chat.openAriaLabel')} class="group">
      <Icon name="mdi:robot-happy-outline" class="w-6 h-6" />
      <span class="chat-toggle-label">{t(lang, 'chat.toggleLabel')}</span>
    </button>

    <div id="chat-panel" class="hidden">
      <header>
        <div class="flex items-center gap-2">
          <Icon name="mdi:robot-happy-outline" class="w-5 h-5 text-accent" />
          <span class="font-heading font-bold text-maintext text-sm">{t(lang, 'chat.headerTitle')}</span>
        </div>
        <div class="flex items-center gap-1">
          <button id="chat-clear" aria-label={t(lang, 'chat.clearTitle')} title={t(lang, 'chat.clearTitle')}>
            <Icon name="mdi:broom" class="w-4 h-4" />
          </button>
          <button id="chat-close" aria-label={t(lang, 'chat.closeTitle')} title={t(lang, 'chat.closeTitle')}>
            <Icon name="mdi:close" class="w-4 h-4" />
          </button>
        </div>
      </header>

      <div id="chat-messages">
        <div class="chat-bubble chat-bubble-assistant">
          {t(lang, 'chat.welcomeMessage')}
        </div>
      </div>

      <div id="chat-suggested">
        {suggestedQuestions.map((q) => (
          <button type="button" class="suggested-question">{q}</button>
        ))}
      </div>

      <div id="chat-error" class="hidden"></div>

      <form id="chat-form">
        <input
          id="chat-input"
          type="text"
          autocomplete="off"
          maxlength="1000"
          placeholder={t(lang, 'chat.inputPlaceholder')}
          aria-label={t(lang, 'chat.inputAriaLabel')}
        />
        <button type="submit" id="chat-send" aria-label={t(lang, 'chat.sendAriaLabel')}>
          <Icon name="mdi:send" class="w-4 h-4" />
        </button>
      </form>
    </div>
  </div>

<style is:global>
  /* Global: chat bubbles are created client-side via document.createElement,
     so they never receive Astro's per-component scope attribute. */
  #chat-widget {
    position: fixed;
    left: 1.5rem;
    bottom: 1.5rem;
    z-index: 50;
  }

  #chat-toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.1rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-background), transparent 15%);
    border: 1px solid color-mix(in srgb, var(--color-accent), transparent 50%);
    backdrop-filter: blur(12px);
    color: var(--color-maintext);
    box-shadow: 0 0 25px color-mix(in srgb, var(--color-accent) 25%, transparent);
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
  }

  #chat-toggle:hover {
    transform: scale(1.05);
    background: color-mix(in srgb, var(--color-accent), transparent 75%);
  }

  .chat-toggle-label {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 500;
    white-space: nowrap;
  }

  #chat-panel {
    position: absolute;
    bottom: calc(100% + 0.75rem);
    left: 0;
    width: min(380px, calc(100vw - 3rem));
    max-height: min(560px, 70vh);
    display: flex;
    flex-direction: column;
    background: color-mix(in srgb, var(--color-background), transparent 6%);
    border: 1px solid color-mix(in srgb, var(--color-accent), transparent 80%);
    border-radius: 1.25rem;
    backdrop-filter: blur(16px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
    overflow: hidden;
    animation: chat-panel-in 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #chat-panel.hidden {
    display: none;
  }

  @keyframes chat-panel-in {
    from { opacity: 0; transform: translateY(12px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  #chat-panel header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-maintext), transparent 90%);
    flex-shrink: 0;
  }

  #chat-panel header button {
    color: var(--color-subtext);
    padding: 0.35rem;
    border-radius: 0.5rem;
    transition: color 0.2s ease, background 0.2s ease;
  }

  #chat-panel header button:hover {
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent), transparent 90%);
  }

  #chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .chat-bubble {
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.5;
    padding: 0.65rem 0.9rem;
    border-radius: 0.9rem;
    max-width: 88%;
    white-space: pre-wrap;
  }

  .chat-bubble-assistant {
    align-self: flex-start;
    background: color-mix(in srgb, var(--color-accent), transparent 92%);
    border: 1px solid color-mix(in srgb, var(--color-accent), transparent 80%);
    color: var(--color-maintext);
    border-bottom-left-radius: 0.25rem;
  }

  .chat-bubble-user {
    align-self: flex-end;
    background: var(--color-accent);
    color: var(--color-background);
    font-weight: 500;
    border-bottom-right-radius: 0.25rem;
  }

  .chat-sources {
    align-self: flex-start;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: -0.35rem;
  }

  .chat-source-tag {
    font-size: 0.65rem;
    padding: 0.15rem 0.5rem;
    border-radius: 0.4rem;
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent), transparent 92%);
    border: 1px solid color-mix(in srgb, var(--color-accent), transparent 78%);
  }

  .chat-typing {
    align-self: flex-start;
    display: flex;
    gap: 0.25rem;
    padding: 0.7rem 0.9rem;
  }

  .chat-typing span {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: var(--color-accent);
    opacity: 0.6;
    animation: chat-typing-bounce 1.2s infinite ease-in-out;
  }

  .chat-typing span:nth-child(2) { animation-delay: 0.15s; }
  .chat-typing span:nth-child(3) { animation-delay: 0.3s; }

  @keyframes chat-typing-bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-4px); opacity: 1; }
  }

  #chat-suggested {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0 1rem 0.75rem;
    flex-shrink: 0;
  }

  .suggested-question {
    font-family: var(--font-body);
    font-size: 0.7rem;
    padding: 0.35rem 0.65rem;
    border-radius: 0.6rem;
    color: var(--color-subtext);
    background: color-mix(in srgb, var(--color-maintext), transparent 94%);
    border: 1px solid color-mix(in srgb, var(--color-maintext), transparent 85%);
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .suggested-question:hover {
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent), transparent 60%);
  }

  #chat-error {
    margin: 0 1rem 0.75rem;
    padding: 0.5rem 0.75rem;
    border-radius: 0.6rem;
    font-size: 0.75rem;
    color: #f87171;
    background: rgba(248, 113, 113, 0.1);
    border: 1px solid rgba(248, 113, 113, 0.3);
  }

  #chat-error.hidden {
    display: none;
  }

  #chat-form {
    display: flex;
    gap: 0.5rem;
    padding: 0.85rem 1rem;
    border-top: 1px solid color-mix(in srgb, var(--color-maintext), transparent 90%);
    flex-shrink: 0;
  }

  #chat-input {
    flex: 1;
    background: color-mix(in srgb, var(--color-maintext), transparent 95%);
    border: 1px solid color-mix(in srgb, var(--color-maintext), transparent 85%);
    border-radius: 0.7rem;
    padding: 0.5rem 0.75rem;
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--color-maintext);
  }

  #chat-input:focus {
    outline: none;
    border-color: color-mix(in srgb, var(--color-accent), transparent 50%);
  }

  #chat-send {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.7rem;
    background: color-mix(in srgb, var(--color-accent), transparent 85%);
    border: 1px solid color-mix(in srgb, var(--color-accent), transparent 55%);
    color: var(--color-accent);
    flex-shrink: 0;
    transition: background 0.2s ease;
  }

  #chat-send:hover {
    background: color-mix(in srgb, var(--color-accent), transparent 70%);
  }

  #chat-send:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media (max-width: 640px) {
    #chat-widget {
      left: 1rem;
      bottom: 5.5rem;
    }

    .chat-toggle-label {
      display: none;
    }

    #chat-toggle {
      padding: 0.85rem;
    }

    #chat-panel {
      width: calc(100vw - 2rem);
      max-height: 65vh;
    }
  }
</style>

<script>
  import { answerQuestion } from '../utils/chatRetrieval.js';

  function initChatWidget() {
    const widget = document.getElementById('chat-widget');
    if (!widget) return;

    const knowledgeDataEl = document.getElementById('chat-knowledge-data');
    const knowledgeBase = JSON.parse(knowledgeDataEl.textContent);
    const configEl = document.getElementById('chat-config-data');
    const chatConfig = JSON.parse(configEl.textContent);

    const toggleBtn = document.getElementById('chat-toggle');
    const panel = document.getElementById('chat-panel');
    const closeBtn = document.getElementById('chat-close');
    const clearBtn = document.getElementById('chat-clear');
    const messagesEl = document.getElementById('chat-messages');
    const suggestedEl = document.getElementById('chat-suggested');
    const errorEl = document.getElementById('chat-error');
    const form = document.getElementById('chat-form');
    const input = document.getElementById('chat-input');
    const sendBtn = document.getElementById('chat-send');

    const WELCOME_HTML = messagesEl.innerHTML;
    const SUGGESTED_HTML = suggestedEl.innerHTML;

    /** @type {{role: 'user' | 'assistant', content: string}[]} */
    let history = [];

    function scrollToBottom() {
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function appendBubble(role, text) {
      const bubble = document.createElement('div');
      bubble.className = `chat-bubble chat-bubble-${role}`;
      bubble.textContent = text;
      messagesEl.appendChild(bubble);
      scrollToBottom();
      return bubble;
    }

    function appendSources(sources) {
      if (!sources || !sources.length) return;
      const wrap = document.createElement('div');
      wrap.className = 'chat-sources';
      sources.slice(0, 4).forEach((s) => {
        const tag = document.createElement('span');
        tag.className = 'chat-source-tag';
        tag.textContent = `${s.type}: ${s.name}`;
        wrap.appendChild(tag);
      });
      messagesEl.appendChild(wrap);
      scrollToBottom();
    }

    function showTyping() {
      const typing = document.createElement('div');
      typing.className = 'chat-typing';
      typing.id = 'chat-typing-indicator';
      typing.innerHTML = '<span></span><span></span><span></span>';
      messagesEl.appendChild(typing);
      scrollToBottom();
      return typing;
    }

    function showError(message) {
      errorEl.textContent = message;
      errorEl.classList.remove('hidden');
    }

    function clearError() {
      errorEl.classList.add('hidden');
      errorEl.textContent = '';
    }

    function sendMessage(text) {
      clearError();
      appendBubble('user', text);
      const priorHistory = history.slice();
      history.push({ role: 'user', content: text });
      history = history.slice(-6);

      suggestedEl.style.display = 'none';
      input.value = '';
      sendBtn.disabled = true;

      const typingEl = showTyping();

      // No network call: this all runs synchronously against the knowledge
      // base embedded in the page. A short artificial delay just keeps the
      // typing indicator from flashing instantly on/off.
      setTimeout(() => {
        typingEl.remove();

        try {
          const { text: answer, sources } = answerQuestion(knowledgeBase, text, priorHistory, chatConfig);
          appendBubble('assistant', answer);
          appendSources(sources);
          history.push({ role: 'assistant', content: answer });
          history = history.slice(-6);
        } catch (err) {
          showError(chatConfig.replies?.processingError || 'Error');
        } finally {
          sendBtn.disabled = false;
        }
      }, 450);
    }

    toggleBtn?.addEventListener('click', () => {
      panel.classList.toggle('hidden');
      if (!panel.classList.contains('hidden')) input.focus();
    });

    closeBtn?.addEventListener('click', () => panel.classList.add('hidden'));

    clearBtn?.addEventListener('click', () => {
      history = [];
      messagesEl.innerHTML = WELCOME_HTML;
      suggestedEl.innerHTML = SUGGESTED_HTML;
      suggestedEl.style.display = 'flex';
      clearError();
      bindSuggestedQuestions();
    });

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const text = input.value.trim();
      if (!text) return;
      sendMessage(text);
    });

    function bindSuggestedQuestions() {
      suggestedEl.querySelectorAll('.suggested-question').forEach((btn) => {
        btn.addEventListener('click', () => sendMessage(btn.textContent.trim()));
      });
    }

    bindSuggestedQuestions();
  }

  initChatWidget();
  document.addEventListener('astro:after-swap', initChatWidget);
</script>
