---
import { Icon } from 'astro-icon/components';
import skillsData from '../data/skills.json';
---

<section id="skills" class="section-container overflow-hidden">
  <div class="container mx-auto">
    <div class="skills-header mb-16">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-maintext mb-2 flex items-center gap-4">
        <span class="text-accent">/</span> Habilidades
      </h2>
      <p class="text-subtext font-body text-sm max-w-md">
        Fortalezas que aplico en cada proyecto, más allá del código
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-5">
      {skillsData.map((skill) => (
        <div class="skill-soft-card group bg-accent/5 border border-accent/10 rounded-2xl p-5 flex flex-col items-center text-center gap-3 hover:border-accent/40 hover:bg-accent/10 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-accent/15 flex items-center justify-center group-hover:bg-accent/20 transition-colors">
            <Icon name={skill.icon} class="w-6 h-6 text-accent group-hover:scale-110 transition-transform" />
          </div>
          <h3 class="text-maintext font-body text-sm font-semibold leading-tight">{skill.name}</h3>
          <p class="text-subtext text-xs leading-snug">{skill.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills-header,
  .skill-soft-card {
    opacity: 0;
    transform: translateY(20px) scale(0.95);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .skills-header.reveal,
  .skill-soft-card.reveal {
    opacity: 1 !important;
    transform: translateY(0) scale(1);
  }
</style>

<script>
  function revealSkills() {
    const header = document.querySelector('.skills-header');
    const cards = document.querySelectorAll('.skill-soft-card');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          if (entry.target.classList.contains('skills-header')) {
            entry.target.classList.add('reveal');
          } else {
            const index = Array.from(cards).indexOf(entry.target);
            setTimeout(() => {
              entry.target.classList.add('reveal');
            }, (index % 5) * 80);
          }
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

    if (header) observer.observe(header);
    cards.forEach((card) => observer.observe(card));
  }

  revealSkills();
  document.addEventListener('astro:after-swap', revealSkills);
</script>
