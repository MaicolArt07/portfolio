# The portfolio is designed to work out-of-the-box using local data 
# located in '/src/data/'. 
#
# If you wish to use a live backend, provide the endpoint below.
#
# API response MUST follow the exact JSON schema found in
# - /src/data/ directory

PUBLIC_API_URL=https://api.example.com

# URL of the deployed Cloudflare Worker that powers the AI chat assistant
# (see /worker). Only known after your first `wrangler deploy` — looks like
# https://maicol-portfolio-chat.<your-subdomain>.workers.dev
PUBLIC_CHAT_API_URL=